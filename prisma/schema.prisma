generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id             String        @id @default(cuid())
  wallet         String        @unique
  webhookUrl     String?
  webhookSecret  String?
  createdAt      DateTime      @default(now())
  lastSeenAt     DateTime      @default(now())

  paymentLinks   PaymentLink[]
  invoices       Invoice[]
  apiKeys        ApiKey[]
}

model PaymentLink {
  id             String             @id @default(cuid())
  merchantWallet String
  merchant       Merchant           @relation(fields: [merchantWallet], references: [wallet])
  token          String
  amount         Decimal            @db.Decimal(20, 6)
  type           String             @default("fixed")
  active         Boolean            @default(true)
  title          String?
  description    String?
  expiresAt      DateTime?
  maxUses        Int?
  createdAt      DateTime           @default(now())
  archivedAt      DateTime?
  interval       String?
  executions     PaymentExecution[]
  recipients     SplitRecipient[]
  invoice        Invoice?
  subscriptions  Subscription[]
}

model Invoice {
  id             String        @id @default(cuid())
  merchantWallet String
  merchant       Merchant      @relation(fields: [merchantWallet], references: [wallet])
  clientName     String?
  clientEmail    String?
  dueDate        DateTime?
  memo           String?       @db.Text
  token          String
  lineItems      InvoiceItem[]
  linkId         String        @unique
  link           PaymentLink   @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  archivedAt      DateTime?

  @@index([merchantWallet])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @db.Decimal(10, 4)
  unitPrice   Decimal @db.Decimal(20, 6)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model SplitRecipient {
  id           String      @id @default(cuid())
  linkId       String
  wallet       String
  basisPoints  Int
  displayOrder Int         @default(0)
  link         PaymentLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
}

model PaymentExecution {
  id                String                 @id @default(cuid())
  clientExecutionId String                 @unique
  linkId            String
  userWallet        String
  inputToken        String
  inputAmount       BigInt
  outputAmount      BigInt
  txSignature       String                 @unique
  status            PaymentExecutionStatus
  metadata          Json?
  distributedAt     DateTime?
  createdAt         DateTime               @default(now())
  link              PaymentLink            @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
}

enum PaymentExecutionStatus {
  pending
  paid
  failed
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
}

enum RenewalStatus {
  pending
  succeeded
  failed
}

model Subscription {
  id               String             @id @default(cuid())
  linkId           String
  link             PaymentLink        @relation(fields: [linkId], references: [id], onDelete: Cascade)
  subscriberWallet String
  status           SubscriptionStatus @default(active)
  currentPeriodEnd DateTime
  cancelledAt      DateTime?
  createdAt        DateTime           @default(now())
  renewals         SubscriptionRenewal[]

  @@unique([linkId, subscriberWallet])
  @@index([subscriberWallet])
  @@index([linkId])
  @@index([status, currentPeriodEnd])
}

model SubscriptionRenewal {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  txSignature    String?      @unique
  status         RenewalStatus
  attemptCount   Int          @default(1)
  dueAt          DateTime
  executedAt     DateTime?
  failureReason  String?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId])
  @@index([status, dueAt])
}

model ApiKey {
  id             String    @id @default(cuid())
  merchantWallet String
  merchant       Merchant  @relation(fields: [merchantWallet], references: [wallet])
  keyHash        String    @unique
  name           String
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([merchantWallet])
}
