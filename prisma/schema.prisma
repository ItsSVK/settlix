generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PaymentLink {
  id             String             @id @default(cuid())
  merchantWallet String
  token          String
  amount         Decimal            @db.Decimal(20, 6)
  type           String             @default("fixed")
  active         Boolean            @default(true)
  title          String?
  description    String?
  webhookUrl     String?
  webhookSecret  String?
  expiresAt      DateTime?
  maxUses        Int?
  createdAt      DateTime           @default(now())
  executions     PaymentExecution[]
  recipients     SplitRecipient[]
}

model SplitRecipient {
  id           String      @id @default(cuid())
  linkId       String
  wallet       String
  basisPoints  Int
  displayOrder Int         @default(0)
  link         PaymentLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
}

model PaymentExecution {
  id                String                 @id @default(cuid())
  clientExecutionId String                 @unique
  linkId            String
  userWallet        String
  inputToken        String
  inputAmount       Decimal                @db.Decimal(30, 18)
  outputAmount      Decimal                @db.Decimal(30, 18)
  txSignature       String                 @unique
  status            PaymentExecutionStatus
  metadata          Json?
  distributedAt     DateTime?
  createdAt         DateTime               @default(now())
  link              PaymentLink            @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
}

enum PaymentExecutionStatus {
  pending
  paid
  failed
}

model ApiKey {
  id             String    @id @default(cuid())
  merchantWallet String
  keyHash        String    @unique
  name           String
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([merchantWallet])
}
